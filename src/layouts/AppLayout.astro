---
import '../styles/design.css'
import '../styles/app.css'
import AppNav from '../components/layout/AppNav.svelte'
import Toaster from '../components/layout/Toaster.svelte'

export interface Props {
  title: string
  description?: string
  activePath?: string
}

const { title, description = '', activePath = '/app/dashboard' } = Astro.props
---

<!doctype html>
<html lang="pl" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Mind Harness</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      .app-wrapper {
        display: flex;
        height: 100vh;
        overflow: hidden;
      }

      .app-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 0;
        background: #050505;
      }

      .app-content-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2rem 2.5rem;
      }

      .app-header {
        margin-bottom: 2rem;
        animation: fade-up 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      .app-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fafafa;
        line-height: 1.3;
      }

      .app-description {
        font-size: 0.875rem;
        color: #a1a1aa;
        margin-top: 0.375rem;
        max-width: 65ch;
      }

      @media (max-width: 768px) {
        .app-content-inner {
          padding: 1.25rem 1rem;
        }
        .app-title {
          font-size: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-wrapper">
      <AppNav activePath={activePath} client:load />
      <main class="app-content">
        <div class="app-content-inner">
          <div class="app-header">
            <h1 class="app-title">{title}</h1>
            {description && <p class="app-description">{description}</p>}
          </div>
          <slot />
        </div>
      </main>
    </div>
    <Toaster client:load />
  </body>
</html>
